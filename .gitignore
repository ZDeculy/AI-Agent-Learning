# =========================================================
# macOS system files
# =========================================================
# Finder 会自动生成这个文件，用来记录文件夹视图信息。
# 对项目没有意义，不需要提交。
.DS_Store


# =========================================================
# Python cache files
# =========================================================
# Python 运行后可能生成的缓存文件，不需要提交。
__pycache__/
*.py[cod]
*$py.class


# =========================================================
# Python virtual environments
# =========================================================
# uv / venv / virtualenv / conda 本地环境都不应该提交。
# 环境可以通过 pyproject.toml、uv.lock、requirements.txt 重新构建。
.venv/
venv/
env/
ENV/


# =========================================================
# Environment variables and secrets
# =========================================================
# .env 常用于保存 API key，例如 OPENAI_API_KEY。
# 这类文件绝对不要上传到 GitHub。
.env
.env.*
*.key
*.pem


# =========================================================
# Logs
# =========================================================
# 程序运行日志一般不需要提交，除非你特意整理成实验记录。
logs/
*.log


# =========================================================
# Temporary files
# =========================================================
# 临时文件、缓存文件。
tmp/
temp/
.cache/


# =========================================================
# Jupyter Notebook checkpoints
# =========================================================
.ipynb_checkpoints/


# =========================================================
# IDE / editor settings
# =========================================================
# 编辑器配置通常是个人偏好，一般不提交。
# 如果你后面想共享 VS Code 配置，可以再单独调整。
.vscode/
.idea/


# =========================================================
# Project private data
# =========================================================
# 后续如果有原始数据、私有论文、实验大文件，可以放这里。
# 注意：不要全局忽略 *.csv 或 *.xlsx，否则小型示例数据也会被忽略。
data/raw/
data/private/
private/
secrets/
